{
  "name": "marquee-content",
  "version": "4.6.1",
  "description": "A lightweight marquee Web Component with Shadow DOM style overrides support",
  "packageManager": "npm@11.16.0",
  "author": "ux-ui.pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ux-ui-pro/marquee-content.git"
  },
  "bugs": {
    "url": "https://github.com/ux-ui-pro/marquee-content/issues"
  },
  "homepage": "https://github.com/ux-ui-pro/marquee-content",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown && node scripts/build-css.mjs",
    "dev": "vite",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run test:smoke && npm run pack:check",
    "lint": "biome check src tests tsdown.config.ts",
    "lint:fix": "biome check --write src tests tsdown.config.ts",
    "format": "biome format --write src tests tsdown.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:smoke": "node --test tests/smoke.test.js",
    "pack:check": "npm pack --dry-run && publint && attw --pack . --profile node16 --exclude-entrypoints marquee-content.css",
    "prepublishOnly": "npm run clean && npm run verify"
  },
  "source": "src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/marquee-content.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./marquee-content.css": "./dist/marquee-content.css",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "web component",
    "web-component",
    "custom elements",
    "custom-elements",
    "marquee",
    "ticker",
    "shadow dom",
    "shadow-dom",
    "ui",
    "component"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "2.4.14",
    "@tsdown/css": "^0.22.3",
    "@types/node": "25.6.0",
    "publint": "^0.3.21",
    "rimraf": "6.1.3",
    "sass-embedded": "^1.100.0",
    "tsdown": "^0.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
